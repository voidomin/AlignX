{
  "name": "Python 3",
  // Or use a Dockerfile or Docker Compose file. More info: https://containers.dev/guide/dockerfile
  "image": "mcr.microsoft.com/devcontainers/python:1-3.11-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    }
  },
  "customizations": {
    "codespaces": {
      "openFiles": [
        "README.md",
        "app.py",
        "src/backend/api.py"
      ]
    },
    "vscode": {
      "settings": {},
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ]
    }
  },
  "updateContentCommand": "[ -f packages.txt ] && sudo apt update && sudo apt upgrade -y && sudo xargs apt install -y <packages.txt; [ -f requirements.txt ] && pip3 install --user -r requirements.txt; pip3 install --user streamlit; (cd web-frontend && npm install && npm run build && rm -rf ../static && cp -r dist ../static); echo '✅ Packages installed and Requirements met'",
  "postAttachCommand": {
    "streamlit": "streamlit run app.py --server.enableCORS false --server.enableXsrfProtection false",
    "api": "uvicorn src.backend.api:app --host 0.0.0.0 --port 8000"
  },
  "portsAttributes": {
    "8501": {
      "label": "Streamlit App",
      "onAutoForward": "openPreview"
    },
    "8000": {
      "label": "FastAPI + Vite SPA",
      "onAutoForward": "notify"
    }
  },
  "forwardPorts": [
    8501,
    8000
  ]
}