@ARTICLE{Sayers2025,
  ABSTRACT = {The National Center for Biotechnology Information (NCBI) provides online information resources for biology, including the GenBank® nucleic acid sequence repository and the PubMed® repository of citations and abstracts published in life science journals. NCBI provides search and retrieval operations for most of these data from 31 distinct repositories and knowledgebases. The E-utilities serve as the programming interface for most of these. Resources receiving significant updates in the past year include PubMed, PubMed Central, Bookshelf, the NIH Comparative Genomics Resource, BLAST, Sequence Read Archive, Taxonomy, iCn3D, Conserved Domain Database, Pathogen Detection, antimicrobial resistance resources and PubChem. These resources can be accessed through the NCBI home page at https://www.ncbi.nlm.nih.gov.},
  AUTHOR = {Sayers, Eric W and Beck, Jeffrey and Bolton, Evan E and Brister, J Rodney and Chan, Jessica and Connor, Ryan and Feldgarden, Michael and Fine, Anna M and Funk, Kathryn and Hoffman, Jinna and Kannan, Sivakumar and Kelly, Christopher and Klimke, William and Kim, Sunghwan and Lathrop, Stacy and Marchler-Bauer, Aron and Murphy, Terence D and O’Sullivan, Chris and Schmieder, Erin and Skripchenko, Yuriy and Stine, Adam and Thibaud-Nissen, Francoise and Wang, Jiyao and Ye, Jian and Zellers, Erin and Schneider, Valerie A and Pruitt, Kim D},
  URL = {https://doi.org/10.1093/nar/gkae979},
  DATE = {2025-01},
