# Environment Variables for AlignX
# Copy this file to .env and customize

# Mustang Backend Selection
# Options: "native", "bio3d", "wsl"
MUSTANG_BACKEND=auto

# Path to Mustang executable
# Examples:
#   Windows WSL: wsl mustang
#   Linux/Mac: /usr/local/bin/mustang
#   Auto-detect: mustang
MUSTANG_PATH=mustang

# Phylip executable path
PHYLIP_PATH=neighbor

# PyMOL executable path  
PYMOL_PATH=pymol

# Working directory for temporary files
WORK_DIR=./temp

# Results output directory
RESULTS_DIR=./results

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# API key required on all /api/* routes (X-API-Key header).
# Leave unset for open local development; set for any deployment
# reachable outside localhost.
ALIGNX_API_KEY=

# Allowed CORS origins for the FastAPI backend, comma-separated.
# Defaults to "*" (any origin) for local development; restrict this to your
# actual frontend origin(s) in production, e.g. https://alignx.example.com
ALIGNX_CORS_ORIGINS=*

# For GCP deployment (optional)
# GCP_PROJECT_ID=your-project-id
# GCP_BUCKET=your-storage-bucket
